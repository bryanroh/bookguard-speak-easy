{
  "expo": {
    "name": "ProWeb",
    "slug": "proweb",
    "scheme": "proweb",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.providencetheology.proweb",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "주변 카메라/촬영 기기 감지를 위해 카메라 권한이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.providencetheology.proweb",
      "permissions": ["CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "주변 촬영 기기 감지를 위해 카메라 접근이 필요합니다."
        }
      ]
    ],
    "extra": {
      "WEB_BASE_URL": "https://your-web-domain.com",
      "SUPABASE_URL": "REPLACE_AT_BUILD",
      "SUPABASE_ANON_KEY": "REPLACE_AT_BUILD"
    }
  }
}
